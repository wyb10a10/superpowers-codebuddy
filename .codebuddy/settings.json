{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "'${SUPERPOWERS_ROOT}/hooks/run-hook.cmd' session-start",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
